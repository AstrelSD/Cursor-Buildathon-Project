# CORS — set to your Vercel frontend URL (no trailing slash)
FRONTEND_URL=https://your-frontend.vercel.app
# Optional extra origins (comma-separated), e.g. custom domain
# CORS_ALLOW_ORIGINS=

# Gemini — vision agent + market RAG embeddings (no OpenAI required)
GOOGLE_GENAI_API_KEY=your-gemini-api-key-here

# Optional — only needed for GPT-4o underwriting narrative logs
OPENAI_API_KEY=

# Supabase: Project Settings → API Keys → Secret key (sb_secret_...)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-key-here

# Must match your Storage bucket name exactly
SUPABASE_STORAGE_BUCKET=loan-evidence

# Vision model (gemini-2.0-* often returns 404 on the current API)
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_VISION_FALLBACK_MODELS=
GEMINI_VISION_MAX_RETRIES=3

# Set true to complete pipeline when Gemini is down/quota (hackathon demo)
MOCK_VISION_ON_FAILURE=true

# Must match model used in scripts/seed_market_intelligence.py
# Re-run seed after district expansion: docker compose run --rm api python scripts/seed_market_intelligence.py
GEMINI_EMBEDDING_MODEL=gemini-embedding-2

# ElevenLabs Agents — server-side only (https://elevenlabs.io/docs/eleven-agents/libraries/react)
ELEVENLABS_API_KEY=your-elevenlabs-api-key
# Create an agent at https://elevenlabs.io/app/agents — copy agent_id (agent_...)
ELEVENLABS_AGENT_ID=agent_your-agent-id

# Seylan hackathon sandbox — all bank calls proxy through this host (x-api-key header only)
SEYLAN_API_KEY=aa16d36b-fea1-45a2-ace7-81042174244f
SEYLAN_SANDBOX_BASE_URL=http://34.21.206.87:3000

# Sandbox test accounts (from hackathon brief)
SEYLAN_SOURCE_ACCOUNT_NUMBER=064000012548001
SEYLAN_INTERNAL_DESTINATION_ACCOUNT=001213437904100
SEYLAN_CEFTS_DESTINATION_ACCOUNT=12345678
SEYLAN_CEFTS_DESTINATION_BANK_CODE=6990

# Merchant QR credentials (required only for POST /loans/{id}/repayment/qr)
SEYLAN_USE_TEST_PREFIX=true
SEYLAN_MID=CURSOR5
SEYLAN_TEST_MID=TESTCURSOR5
SEYLAN_MERCHANT_LOGIN_ID=CURSOR5op
SEYLAN_TEST_MERCHANT_LOGIN_ID=TCURSOR5op
SEYLAN_MERCHANT_LOGIN_PASS=
SEYLAN_TEST_MERCHANT_LOGIN_PASS=TPassword@55#5
SEYLAN_QR_INSTITUTION_ID=1
SEYLAN_QR_CHANNEL_USER_ID=
SEYLAN_QR_CHANNEL_PASS=
SEYLAN_QR_CHECKSUM_KEY=
SEYLAN_SOURCE_CUSTOMER_NAME=Cursor Buildathon 5
SEYLAN_SOURCE_BANK_CODE=6287

# Mock disbursement/QR until sandbox Posting is enabled (set false for live CEFTS).
# Balance Inquiry still calls the sandbox when SEYLAN_API_KEY is set (works with MOCK_BANKING=true).
SEYLAN_MOCK_BANKING=true
SEYLAN_FALLBACK_TO_MOCK_ON_ERROR=true
