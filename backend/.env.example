# Required to boot the API with Gemini (Phase 2 vision agent)
GOOGLE_GENAI_API_KEY=your-gemini-api-key-here

# Optional until Phase 2+ (leave blank or delete the line)
OPENAI_API_KEY=

# Supabase: Project Settings → API Keys → Secret key (sb_secret_...)
# Legacy JWT service_role keys (eyJ...) also work.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-key-here
