# Gemini — vision agent + market RAG embeddings (no OpenAI required)
GOOGLE_GENAI_API_KEY=your-gemini-api-key-here

# Optional — only needed for GPT-4o underwriting narrative logs
OPENAI_API_KEY=

# Supabase: Project Settings → API Keys → Secret key (sb_secret_...)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-key-here

# Must match your Storage bucket name exactly
SUPABASE_STORAGE_BUCKET=loan-evidence

# Vision model (use gemini-1.5-flash if 2.0-flash hits quota)
GEMINI_VISION_MODEL=gemini-1.5-flash

# Set true to complete pipeline when Gemini quota is exhausted (hackathon demo)
MOCK_VISION_ON_FAILURE=false

# Must match model used in scripts/seed_market_intelligence.py
# Re-run seed after district expansion: docker compose run --rm api python scripts/seed_market_intelligence.py
GEMINI_EMBEDDING_MODEL=gemini-embedding-2

# ElevenLabs Agents — server-side only (https://elevenlabs.io/docs/eleven-agents/libraries/react)
ELEVENLABS_API_KEY=your-elevenlabs-api-key
# Create an agent at https://elevenlabs.io/app/agents — copy agent_id (agent_...)
ELEVENLABS_AGENT_ID=agent_your-agent-id
